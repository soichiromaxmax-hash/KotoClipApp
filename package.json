{
  "name": "kotoclipapp",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "eslint . --no-cache",
    "release:ios:check": "expo config --type introspect && eslint . --no-cache",
    "release:ios:build": "eas build --platform ios --profile production --auto-submit",
    "release:ota": "cross-env EAS_SKIP_AUTO_FINGERPRINT=1 eas update --branch production --environment production",
    "postinstall": "python3 scripts/patch-expo-swift.py || true"
  },
  "dependencies": {
    "@expo-google-fonts/lobster-two": "^0.4.1",
    "@expo-google-fonts/space-grotesk": "^0.4.1",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "expo": "~55.0.26",
    "expo-constants": "~55.0.16",
    "expo-font": "~55.0.8",
    "expo-haptics": "~55.0.14",
    "expo-image": "~55.0.11",
    "expo-linear-gradient": "~55.0.14",
    "expo-linking": "~55.0.15",
    "expo-notifications": "~55.0.23",
    "expo-router": "~55.0.16",
    "expo-sharing": "~55.0.20",
    "expo-splash-screen": "~55.0.21",
    "expo-status-bar": "~55.0.6",
    "expo-symbols": "~55.0.9",
    "expo-system-ui": "~55.0.18",
    "expo-updates": "~55.0.24",
    "expo-web-browser": "~55.0.16",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-purchases": "^10.2.2",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-view-shot": "4.0.3",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "0.7.4",
    "shared-storage": "file:./modules/shared-storage"
  },
  "devDependencies": {
    "@types/react": "~19.2.10",
    "cross-env": "^10.1.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "^55.0.1",
    "typescript": "~5.9.2"
  },
  "private": true
}
