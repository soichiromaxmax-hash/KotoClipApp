# Enforce LF line endings for all iOS-related files
# (CRLF causes shell errors when sourced on macOS)
*.swift text eol=lf
*.sh text eol=lf
*.rb text eol=lf
*.py text eol=lf
*.env text eol=lf
*.plist text eol=lf
*.entitlements text eol=lf
*.pbxproj text eol=lf
*.xcscheme text eol=lf
*.storyboard text eol=lf
*.json text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.jsx text eol=lf
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
Podfile text eol=lf
Podfile.lock text eol=lf
